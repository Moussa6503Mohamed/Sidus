# Local PostgreSQL (docker-compose.yml)
POSTGRES_USER=sidus
POSTGRES_PASSWORD=sidus_dev_password
POSTGRES_DB=sidus
POSTGRES_PORT=5432

# services/core connection string (used by services/core and cmd/migrate)
DATABASE_URL=postgres://sidus:sidus_dev_password@localhost:5432/sidus?sslmode=disable

# --- Clerk authentication (T-0003) — PLACEHOLDERS ONLY ---
# Real keys live only in gitignored .env.local files. Never commit real keys here.
# Get these from the Clerk Dashboard (see docs/auth-setup.md).

# Web (apps/web) — put real values in the gitignored apps/web/.env.local, not here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Core (services/core) session verification.
# CLERK_JWT_ISSUER pins the accepted token issuer (your Clerk Frontend API URL).
# CLERK_AUTHORIZED_PARTIES is a comma-separated allow-list of accepted request origins (azp).
# Development default (when unset) is the local Sidus web origin only.
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# AI (services/ai) session verification. CLERK_JWKS_URL defaults to
# <CLERK_JWT_ISSUER>/.well-known/jwks.json when unset.
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
